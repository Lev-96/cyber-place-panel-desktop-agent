{
  "name": "cyber-place-client-agent",
  "version": "1.0.15",
  "private": true,
  "main": "electron/dist/main.js",
  "description": "Cyber Place kiosk agent — runs on each gaming PC, locks the workstation when no session is active, and unlocks when the cashier starts one.",
  "homepage": "https://cyberplace.pro",
  "license": "UNLICENSED",
  "author": {
    "name": "Cyber Place",
    "email": "support@cyberplace.pro",
    "url": "https://cyberplace.pro"
  },
  "scripts": {
    "dev": "vite",
    "build:web": "tsc -p tsconfig.app.json && vite build",
    "build:electron": "tsc -p electron/tsconfig.json",
    "build": "npm run build:web && npm run build:electron",
    "electron:dev": "ELECTRON_DEV_URL=http://localhost:5174 npm run build:electron && electron electron/dist/main.js",
    "dist:linux": "npm run build && electron-builder --linux",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "typecheck": "tsc -p tsconfig.app.json --noEmit && tsc -p electron/tsconfig.json --noEmit"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^20.12.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
