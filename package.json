{
  "name": "cyber-place-client-agent",
  "version": "1.0.0",
  "private": true,
  "main": "electron/dist/main.js",
  "author": "Cyber Place <dev@develop.com>",
  "homepage": "https://cyberplace.app",
  "scripts": {
    "dev": "vite",
    "build:web": "tsc -p tsconfig.app.json && vite build",
    "build:electron": "tsc -p electron/tsconfig.json",
    "build": "npm run build:web && npm run build:electron",
    "electron:dev": "ELECTRON_DEV_URL=http://localhost:5174 npm run build:electron && electron electron/dist/main.js",
    "dist:linux": "npm run build && electron-builder --linux",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "typecheck": "tsc -p tsconfig.app.json --noEmit && tsc -p electron/tsconfig.json --noEmit"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
